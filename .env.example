# Lemon Squeezy licence key (received after purchase)
LICENCE_KEY=

# Enable Banking credentials (from enablebanking.com control panel)
EB_APP_ID=
EB_PRIVATE_KEY_PATH=/app/data/eb_private.key

# Notion
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Email notifications (iCloud SMTP)
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# Sync time in HH:MM format (24h, your local timezone)
SYNC_TIME=08:00

# Flask secret key (generate any random string)
SECRET_KEY=change-me-to-something-random
